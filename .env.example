# ============================================================
# "Claro que Eu vendo!" v2 — exemplo de configuração
# Copie para .env e preencha. NUNCA faça commit do .env real.
# ============================================================

# --- LLM ---
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Limites do agente (custo/latência) ---
LLM_MAX_TOKENS=4096
AGENT_TIMEOUT_SECONDS=90
AGENT_RECURSION_LIMIT=12
HISTORY_MAX_MESSAGES=20

# --- Web Search ---
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# --- Observabilidade (LangFuse) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# --- Auth / JWT ---
# GERE UM SEGREDO FORTE: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=troque-por-um-segredo-aleatorio-forte
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Cookie de sessão (defina COOKIE_SECURE=true quando servir via HTTPS)
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# --- Bootstrap do primeiro usuário root (VULN-03) ---
# Opção A (recomendada): criar root automaticamente no startup.
ROOT_USERNAME=
ROOT_PASSWORD=
# Opção B: habilitar setup via web exigindo este token (deixe vazio p/ desabilitar).
SETUP_TOKEN=

# --- CORS (origens permitidas, separadas por vírgula) ---
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Segurança de saída ---
PII_MASKING=true

# --- Database ---
DATABASE_URL=sqlite:///./data/app.db
